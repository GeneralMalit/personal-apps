{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "timestamp-copy",
  "version": "0.1.0",
  "identifier": "com.generalmalit.timestampcopy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "background",
        "title": "timestamp-copy",
        "width": 360,
        "height": 180,
        "visible": false,
        "focus": false,
        "skipTaskbar": true,
        "resizable": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
